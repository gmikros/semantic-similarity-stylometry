# Normalize line endings: store text as LF in the repo.
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.R     text eol=lf
*.r     text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.cff   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows-only scripts keep CRLF
*.ps1   text eol=crlf

# Binary assets (never normalize/diff)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.docx  binary
*.xlsx  binary
